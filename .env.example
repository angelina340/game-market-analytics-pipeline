RAWG_API_KEY=your_rawg_api_key
STEAM_API_KEY=your_steam_api_key
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_RAW_PREFIX=raw

# Optional aliases supported by the app
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=your-bucket-name
# AWS_RAW_PREFIX=raw

SNOWFLAKE_ACCOUNT=your-snowflake-account
SNOWFLAKE_USER=your-snowflake-user
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_WAREHOUSE=your-snowflake-warehouse
SNOWFLAKE_DATABASE=GAME_ANALYTICS
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=your-snowflake-role
SNOWFLAKE_AUTHENTICATOR=username_password_mfa
# Optional for accounts that require TOTP-based MFA during connector login
# SNOWFLAKE_MFA_PASSCODE=123456

# Preferred for automation and Airflow:
# SNOWFLAKE_PRIVATE_KEY_PATH=.keys/snowflake_rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your-private-key-passphrase
